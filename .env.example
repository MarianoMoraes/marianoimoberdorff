# ===========================================
# Instagram Automation - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to the repo.

# Meta / Instagram Graph API
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
INSTAGRAM_ACCESS_TOKEN=your_long_lived_access_token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_ig_business_account_id

# n8n Cloud
N8N_CLOUD_URL=https://your-instance.app.n8n.cloud
N8N_API_KEY=your_n8n_api_key

# Optional - AI DM Chatbot (Phase 2)
# OPENAI_API_KEY=your_openai_api_key
